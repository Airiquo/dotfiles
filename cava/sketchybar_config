[general]
bars = 35
framerate = 30
sleep_timer = 0
autosens = 1
sensitivity = 200

[input]
method = portaudio
source = BlackHole 2ch

[output]
method = raw
channels = mono
raw_target = /tmp/cava_sketchybar.fifo
data_format = ascii
ascii_max_range = 7
bar_delimiter = 59
frame_delimiter = 10

[smoothing]
noise_reduction = 30
monstercat = 1
